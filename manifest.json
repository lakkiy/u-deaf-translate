{
  "manifest_version": 3,
  "name": "叫你翻译你聋吗",
  "version": "0.1.0",
  "description": "选中网页文字 → 自动翻译为中文，本地推理零联网。Translate selected text to Chinese using Chrome's on-device Translator API.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content.ts"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
